rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the currently logged-in user is the master administrator
    function isMasterAdmin() {
      return isAuthenticated() && request.auth.token.email == "islamrwanda18@gmail.com";
    }

    // Check if the requesting user has been approved by the master admin
    function isApprovedAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    // ─── Users Collection ───────────────────────────────────────────────
    // Stores admin profiles (firstName, lastName, email, approved, etc.)
    match /users/{userId} {
      // Master admin can read all users; regular users can read their own profile
      allow read: if isMasterAdmin() || (isAuthenticated() && request.auth.uid == userId);
      
      // A new user can create their own profile during signup,
      // but they CANNOT set themselves as approved
      allow create: if isAuthenticated() && 
                       request.auth.uid == userId && 
                       request.resource.data.approved == false;
      
      // Master admin can update any profile (approve/disable users).
      // Regular users can update their own profile but CANNOT change their approval status.
      allow update: if isMasterAdmin() || 
                       (isAuthenticated() && request.auth.uid == userId && 
                        request.resource.data.approved == resource.data.approved);
      
      // Only the master admin can delete user accounts
      allow delete: if isMasterAdmin();
    }

    // ─── Board Members Collection ───────────────────────────────────────
    // Only the master admin (islamrwanda18@gmail.com) can manage board members.
    // Everyone can read.
    match /board/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }

    // ─── Public Content Collections ─────────────────────────────────────
    // Services, Programs, News, Partners, X Posts
    // Anyone can read. Approved admins or master admin can write.

    match /services/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /news/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /partners/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /xposts/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    // ─── Globals (Singletons: Mission, Vision, History) ─────────────────
    match /globals/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

  }
}

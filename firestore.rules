rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the currently logged-in user is the master administrator
    function isMasterAdmin() {
      return isAuthenticated() && request.auth.token.email == "islamrwanda18@gmail.com";
    }

    // Check if the requesting user has been approved by the master admin
    function isApprovedAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    // ─── Users Collection ───────────────────────────────────────────────
    // Stores admin profiles (firstName, lastName, email, approved, etc.)
    match /users/{userId} {
      allow read: if isMasterAdmin() || (isAuthenticated() && request.auth.uid == userId);
      
      // Allow creation during signup, but must be unapproved by default
      allow create: if isAuthenticated() && 
                       request.auth.uid == userId && 
                       request.resource.data.approved == false;
      
      // Master admin can update anything (approval). 
      // Users can update their own data but not their approval status.
      allow update: if isMasterAdmin() || 
                       (isAuthenticated() && request.auth.uid == userId && 
                        request.resource.data.approved == resource.data.approved);
                        
      allow delete: if isMasterAdmin();
    }

    // ─── Site Configuration (Header, Footer) ──────────────────────────
    // Only the master admin can configure the site's bones.
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }

    // ─── Board Members ──────────────────────────────────────────────────
    // Historically managed by master admin only.
    match /board/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }

    // ─── CMS Content Collections ────────────────────────────────────────
    // Services, Programs, News, Partners, XPosts, Globals (Mission/Vision)
    // Read by everyone, written by any approved admin or master admin.

    match /services/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /news/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /partners/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /xposts/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    match /globals/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin() || isApprovedAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
